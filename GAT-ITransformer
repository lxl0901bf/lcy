# 3. 数据集与模型架构
# ==========================================
class LocalDiskDataset(Dataset):
    """归一化在 __getitem__ 中完成；返回 raw_last_x 供物理惩罚使用"""
    def __init__(self, features, targets, seq_len, pred_len,
                 global_mu, global_std, start_idx=0, end_idx=None,
                 norm_clip=10.0):
        self.features = features
        self.targets  = targets
        self.seq_len  = seq_len
        self.pred_len = pred_len
        self.start_idx = start_idx
        self.end_idx   = end_idx if end_idx is not None else features.shape[0]
        self.valid_steps = max(0, (self.end_idx - self.start_idx) - self.seq_len - self.pred_len + 1)
        self.norm_clip = float(norm_clip)

        self.mu  = torch.as_tensor(global_mu,  dtype=torch.float32)
        self.std = torch.as_tensor(global_std, dtype=torch.float32)

        target_dim = targets.shape[-1]
        self.target_mu  = self.mu[:,  :target_dim]
        self.target_std = self.std[:, :target_dim]

        assert self.mu.shape == (features.shape[1], features.shape[2]), \
            f"mu shape 应为 ({features.shape[1]}, {features.shape[2]})，实际为 {self.mu.shape}"
        assert self.std.shape == self.mu.shape, \
            f"std shape {self.std.shape} 与 mu {self.mu.shape} 不一致"

    def __len__(self):
        return self.valid_steps

    def __getitem__(self, idx):
        actual_idx = self.start_idx + idx

        raw_x = torch.as_tensor(
            self.features[actual_idx: actual_idx + self.seq_len],
            dtype=torch.float32
        )

        raw_y = torch.as_tensor(
            self.targets[actual_idx + self.seq_len: actual_idx + self.seq_len + self.pred_len],
            dtype=torch.float32
        )

        raw_x = torch.nan_to_num(raw_x, nan=0.0, posinf=0.0, neginf=0.0)
        raw_y = torch.nan_to_num(raw_y, nan=0.0, posinf=0.0, neginf=0.0)

        X_norm = (raw_x - self.mu)  / self.std
        Y_norm = (raw_y - self.target_mu) / self.target_std

        X_norm = torch.clamp(X_norm, -self.norm_clip, self.norm_clip)
        Y_norm = torch.clamp(Y_norm, -self.norm_clip, self.norm_clip)
        X_norm = torch.nan_to_num(X_norm, nan=0.0, posinf=0.0, neginf=0.0)
        Y_norm = torch.nan_to_num(Y_norm, nan=0.0, posinf=0.0, neginf=0.0)

        raw_last_x = raw_x[-1]

        return X_norm, Y_norm, self.target_mu, self.target_std, raw_last_x


# ==========================================
# 监督式 Iterative Refinement 模块（替代 PPO Agent）
# ==========================================
class RefinementBlock(nn.Module):
    """
    监督式迭代细化模块（替代原 PPO_Agent）
    输入: context 编码 + 当前预测轨迹
    输出: 对当前轨迹的残差修正
    """
    def __init__(self, d_model: int, target_dim: int, max_delta: float = 0.3):
        super().__init__()
        self.max_delta = float(max_delta)
        self.state_encoder = nn.Sequential(
            nn.Linear(d_model + target_dim, d_model),
            nn.LayerNorm(d_model),
            nn.GELU(),
            nn.Linear(d_model, d_model)
        )
        self.delta_head = nn.Sequential(
            nn.Linear(d_model, d_model),
            nn.GELU(),
            nn.Dropout(0.1),
            nn.Linear(d_model, target_dim)
        )
        self.gate = nn.Sequential(
            nn.Linear(d_model, target_dim),
            nn.Sigmoid()
        )

    def forward(self, context_emb, current_trajectory):
        s = self.state_encoder(torch.cat([context_emb, current_trajectory], dim=-1))
        delta = torch.tanh(self.delta_head(s)) * self.max_delta
        gate = self.gate(s)
        return delta * gate


class ST_GCN_iTransformer(nn.Module):
    """
    时空预测模型 (iTransformer 风格)

    架构:
    1. 输入投影 + TCN 局部时序卷积
    2. GAT 空间消息传递（带风向边特征）
    3. ⭐ iTransformer 风格的时间嵌入（Linear 投影,取代 Conv 时间压缩器）
    4. Transformer Encoder 站点间交互
    5. 基础预测头 + 多步监督式迭代细化
    """
    def __init__(self, num_nodes, in_features, seq_len, pred_len, out_channels,
                 physics_indices, d_model=192, n_heads=8, num_layers=4,
                 dropout=0.3, refinement_steps=3,
                 time_embedding_hidden_mult=2):
        super().__init__()
        self.refinement_steps = int(refinement_steps)
        self.d_model = int(d_model)
        self.pred_len = int(pred_len)
        self.out_channels = int(out_channels)
        self.target_dim = int(self.pred_len * self.out_channels)
        self.num_nodes = int(num_nodes)
        self.seq_len = int(seq_len)
        self.physics_indices = physics_indices

        self.input_proj = nn.Linear(in_features, d_model)
        self.tcn = nn.Conv1d(in_channels=d_model, out_channels=d_model, kernel_size=3, padding=1)
        self.gat = GATConv(d_model, d_model // n_heads, heads=n_heads,
                           concat=True, dropout=dropout, edge_dim=4)
        self.gcn_norm = nn.LayerNorm(d_model)

        # ⭐ iTransformer 风格的时间嵌入
        # 每个 d_model 通道的时序整条 (T 步) 通过 Linear 直接投影成单值
        # 取代原来的 time_compressor (3×Conv1d + AvgPool) 和 time_projector (MLP)
        # 输入:  (..., T)        T = seq_len = 336
        # 输出:  (..., 1)         压缩成 1 个数值
        # 用稍带瓶颈的 MLP 替代纯 Linear,提升表达力但保留全局感受野
        hidden = int(seq_len * time_embedding_hidden_mult)
        self.time_embedding = nn.Sequential(
            nn.Linear(seq_len, hidden),
            nn.GELU(),
            nn.Dropout(dropout),
            nn.Linear(hidden, 1)
        )

        # Transformer 在站点维度做 attention（iTransformer 核心思想）
        self.transformer = nn.TransformerEncoder(
            nn.TransformerEncoderLayer(
                d_model=d_model, nhead=n_heads, dim_feedforward=d_model * 4,
                dropout=dropout, activation='gelu', batch_first=True, norm_first=True
            ),
            num_layers=num_layers, enable_nested_tensor=False
        )

        # 基础预测头
        self.base_predictor = nn.Sequential(
            nn.Linear(d_model, d_model * 2),
            nn.GELU(),
            nn.Dropout(dropout),
            nn.Linear(d_model * 2, self.target_dim)
        )

        # 监督式迭代细化模块
        self.refinement_blocks = nn.ModuleList([
            RefinementBlock(d_model, self.target_dim, max_delta=0.3)
            for _ in range(self.refinement_steps)
        ])

    def _encode_context(self, x, edge_index, edge_attr_static):
        """提取 (B, N, d_model) 的上下文编码"""
        B, T, N, _ = x.shape
        u_raw = x[..., self.physics_indices['u']].reshape(B * T, N)
        v_raw = x[..., self.physics_indices['v']].reshape(B * T, N)

        x_emb = self.input_proj(x)
        x_local = F.gelu(
            self.tcn(x_emb.permute(0, 2, 3, 1).reshape(B * N, self.d_model, T))
        ).reshape(B, N, self.d_model, T).permute(0, 3, 1, 2).contiguous() + x_emb
        x_flat = x_local.reshape(B * T, N, self.d_model)

        E = edge_index.shape[1]
        chunk_size = 32
        padded_len = B * T + ((chunk_size - (B * T) % chunk_size) if (B * T) % chunk_size != 0 else 0)

        if padded_len > B * T:
            x_flat_padded = torch.cat(
                [x_flat, torch.zeros(padded_len - B * T, N, self.d_model, device=x.device)], dim=0
            )
            u_raw_padded = torch.cat(
                [u_raw, torch.zeros(padded_len - B * T, N, device=x.device)], dim=0
            )
            v_raw_padded = torch.cat(
                [v_raw, torch.zeros(padded_len - B * T, N, device=x.device)], dim=0
            )
        else:
            x_flat_padded, u_raw_padded, v_raw_padded = x_flat, u_raw, v_raw

        h_spatial_list = []
        offsets = (torch.arange(chunk_size, device=x.device) * N).repeat_interleave(E).unsqueeze(0)
        edge_index_chunk_base = edge_index.repeat(1, chunk_size) + offsets

        for i in range(0, padded_len, chunk_size):
            u_chunk = u_raw_padded[i: i + chunk_size]
            v_chunk = v_raw_padded[i: i + chunk_size]

            u_t_all = u_chunk[:, edge_index[0]]
            v_t_all = v_chunk[:, edge_index[0]]
            dx = edge_attr_static[:, 0]
            dy = edge_attr_static[:, 1]
            wind_proj_all = u_t_all * dx + v_t_all * dy

            dist_log = torch.log1p(edge_attr_static[:, 2:3])
            norm_dist = dist_log / 10.0
            static_part = torch.cat([edge_attr_static[:, 0:2], norm_dist], dim=-1)
            static_part_expanded = static_part.unsqueeze(0).expand(chunk_size, E, 3)
            batch_edge_attr_3d = torch.cat([static_part_expanded, wind_proj_all.unsqueeze(-1)], dim=-1)
            batch_edge_attr = batch_edge_attr_3d.reshape(chunk_size * E, 4)

            out_gat = self.gat(
                x_flat_padded[i: i + chunk_size].reshape(chunk_size * N, self.d_model),
                edge_index_chunk_base,
                edge_attr=batch_edge_attr
            )
            h_spatial_list.append(out_gat)

        h_spatial_cat = torch.cat(h_spatial_list, dim=0)[:B * T * N]
        h_spatial = F.elu(self.gcn_norm(h_spatial_cat)).reshape(B, T, N, self.d_model)
        # h_spatial shape: (B, T, N, d_model)

        # ⭐ iTransformer 风格时间嵌入
        # 重排到 (B, N, d_model, T)，让 T 成为最后一维便于 Linear 投影
        h_spatial_rearranged = h_spatial.permute(0, 2, 3, 1).contiguous()  # (B, N, d_model, T)

        # Linear(T → 1)：每个 d_model 通道的整条时序压缩成 1 个值
        # 这一步等价于学到 T 个权重对时间步加权求和，全局感受野
        time_feat = self.time_embedding(h_spatial_rearranged).squeeze(-1)  # (B, N, d_model)

        # Transformer 在 N（站点）维度做 self-attention，符合 iTransformer 哲学
        context_enc = self.transformer(time_feat)  # (B, N, d_model)
        return context_enc

    def forward(self, x, edge_index, edge_attr_static, return_all_steps=False):
        """
        return_all_steps=False: 返回最终预测 (B, pred_len, N, out_channels)
        return_all_steps=True : 返回 base + 每步 refinement 的中间结果 list（用于深度监督）
        """
        B = x.shape[0]
        N = x.shape[2]

        context_enc = self._encode_context(x, edge_index, edge_attr_static)
        base_preds = self.base_predictor(context_enc)

        all_preds = [base_preds]
        traj = base_preds
        for block in self.refinement_blocks:
            traj = traj + block(context_enc, traj)
            all_preds.append(traj)

        def _reshape(p):
            return p.reshape(B, N, self.pred_len, self.out_channels).permute(0, 2, 1, 3).contiguous()

        if return_all_steps:
            return [_reshape(p) for p in all_preds]
        else:
            return _reshape(all_preds[-1])


