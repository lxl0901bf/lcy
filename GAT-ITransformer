def main():
    set_deterministic_environment(42)

    pipeline = DataIngestionPipeline(
        station_dirs=[f"/home/lcy/data/全国空气质量/站点_{yr}0101-{yr}1231" for yr in range(2016, 2026)],
        station_meta_path="/home/lcy/data/全国空气质量/site.xlsx",
        era5_dir="/home/lcy/data/era5",
        modis_dir="/home/lcy/data/MODIS",
        himawari_dir="/home/lcy/data/himawari_L3031/031"
    )

    target_columns = ['PM2.5', 'PM10', 'NO2', 'SO2', 'O3', 'CO']
    pipeline.process_and_cache(target_cols=target_columns)

    sample_feat = np.load(pipeline.features_cache)
    sample_targ = np.load(pipeline.targets_cache)

    if not np.isfinite(sample_feat).all():
        logger.warning("sample_feat 含 NaN/Inf，强制清洗")
        sample_feat = np.nan_to_num(sample_feat, nan=0.0, posinf=0.0, neginf=0.0)
    if not np.isfinite(sample_targ).all():
        logger.warning("sample_targ 含 NaN/Inf，强制清洗")
        sample_targ = np.nan_to_num(sample_targ, nan=0.0, posinf=0.0, neginf=0.0)

    edge_index, edge_attr_static = pipeline.build_physics_geographic_graph(
        radius_km=100.0, max_neighbors=8
    )

    config = {
        'seq_len': 336,
        'pred_len': 72,
        'd_model': 192,
        'dropout': 0.3,
        'batch_size': 4,
        'lr': 3e-5,
        'lambda_phys': 0.02,
        'lambda_nonneg': 0.001,
        'epochs': 40,
        'device': device,
        'target_columns': target_columns,
        'refinement_steps': 3,
        'warmup_steps': 1000,
    }

    total_time_steps = sample_feat.shape[0]
    train_end = int(total_time_steps * 0.7)
    val_end   = int(total_time_steps * 0.8)

    train_feat = sample_feat[:train_end]
    global_mu  = np.mean(train_feat, axis=0)
    global_std = np.std(train_feat,  axis=0)

    global_mu  = np.where(np.isfinite(global_mu),  global_mu,  0.0).astype(np.float32)
    global_std = np.where(np.isfinite(global_std), global_std, 1.0).astype(np.float32)
    global_std = np.where(global_std < 1e-2, 1.0, global_std)

    assert global_mu.shape  == (sample_feat.shape[1], sample_feat.shape[2])
    assert global_std.shape == global_mu.shape
    assert np.isfinite(global_mu).all()
    assert np.isfinite(global_std).all()
    assert (global_std > 0).all()
    logger.info(f"全局统计 shape: mu={global_mu.shape}, std={global_std.shape}")
    logger.info(f"std 范围: [{global_std.min():.4f}, {global_std.max():.4f}]")
    logger.info(f"mu 范围:  [{global_mu.min():.4f}, {global_mu.max():.4f}]")

    val_start_idx  = max(0, train_end - config['seq_len'])
    test_start_idx = max(0, val_end   - config['seq_len'])

    train_dataset = LocalDiskDataset(sample_feat, sample_targ, config['seq_len'], config['pred_len'],
                                     global_mu, global_std, 0, train_end)
    val_dataset   = LocalDiskDataset(sample_feat, sample_targ, config['seq_len'], config['pred_len'],
                                     global_mu, global_std, val_start_idx, val_end)
    test_dataset  = LocalDiskDataset(sample_feat, sample_targ, config['seq_len'], config['pred_len'],
                                     global_mu, global_std, test_start_idx, total_time_steps)

    train_loader = DataLoader(
        train_dataset, batch_size=config['batch_size'], shuffle=True, drop_last=True,
        num_workers=min(os.cpu_count() or 8, 12), pin_memory=True
    )
    val_loader = DataLoader(
        val_dataset, batch_size=config['batch_size'], shuffle=False, drop_last=False,
        num_workers=min(os.cpu_count() or 4, 4), pin_memory=True
    )
    test_loader = DataLoader(
        test_dataset, batch_size=config['batch_size'], shuffle=False, drop_last=False,
        num_workers=min(os.cpu_count() or 4, 4), pin_memory=True
    )

    model = ST_GCN_iTransformer(
        num_nodes       = int(sample_feat.shape[1]),
        in_features     = int(sample_feat.shape[-1]),
        seq_len         = config['seq_len'],
        pred_len        = config['pred_len'],
        out_channels    = int(sample_targ.shape[-1]),
        physics_indices = pipeline.physics_indices,
        d_model         = config['d_model'],
        dropout         = config['dropout'],
        refinement_steps= config['refinement_steps']
    ).to(config['device'])

    n_params = sum(p.numel() for p in model.parameters())
    logger.info(f"模型参数量: {n_params/1e6:.2f}M")

    trainer = ForecastingPipeline(model, config, edge_index, edge_attr_static, pipeline.physics_indices)
    trainer.train_and_evaluate(train_loader, val_loader, save_dir="./save_models")

    logger.info("\n=== 阶段二: 测试集评估 ===")
    best_path = os.path.join("./save_models", "ST_GCN_best.pth")
    if os.path.exists(best_path):
        checkpoint = torch.load(best_path, map_location=config['device'], weights_only=False)
        model.load_state_dict(checkpoint['model_state_dict'])
        if 'ema_shadow' in checkpoint:
            trainer.ema.load_state_dict(checkpoint['ema_shadow'])
            trainer.ema.apply_shadow()
        model.eval()
        test_rmse, test_rmse_v, test_r2, test_r2_v, test_phys = trainer.evaluate_rmse(test_loader)
        logger.info(f"测试结果 | RMSE: {test_rmse:.4f}, R2: {test_r2:.4f}, Phys: {test_phys:.4f}")
        for k in test_rmse_v:
            logger.info(f"  {k}: RMSE={test_rmse_v[k]:.2f}, R2={test_r2_v[k]:.3f}")
        if 'ema_shadow' in checkpoint:
            trainer.ema.restore()
    else:
        logger.warning("未找到最佳模型，测试评估取消。")


