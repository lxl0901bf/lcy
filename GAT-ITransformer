class ExponentialMovingAverage:
    """EMA 影子权重"""
    def __init__(self, model, decay=0.999):
        self.model = model
        self.decay = decay
        self.shadow = {}
        self.backup = {}
        for name, param in self.model.named_parameters():
            if param.requires_grad:
                self.shadow[name] = param.data.clone().detach()

    def update(self):
        for name, param in self.model.named_parameters():
            if param.requires_grad:
                assert name in self.shadow
                new_average = (1.0 - self.decay) * param.data + self.decay * self.shadow[name]
                self.shadow[name] = new_average.clone().detach()

    def apply_shadow(self):
        for name, param in self.model.named_parameters():
            if param.requires_grad:
                self.backup[name] = param.data
                param.data = self.shadow[name]

    def restore(self):
        for name, param in self.model.named_parameters():
            if param.requires_grad:
                assert name in self.backup
                param.data = self.backup[name]
        self.backup = {}

    def state_dict(self): return self.shadow
    def load_state_dict(self, state_dict): self.shadow = state_dict


class DataIngestionPipeline:
    def __init__(self, station_dirs: list, station_meta_path: str, era5_dir: str, modis_dir: str, himawari_dir: str, cache_dir: str = "./cache"):
        self.station_dirs = station_dirs
        self.station_meta_path = station_meta_path
        self.era5_dir = era5_dir
        self.modis_dir = modis_dir
        self.himawari_dir = himawari_dir
        self.cache_dir = cache_dir
        os.makedirs(self.cache_dir, exist_ok=True)

        self.features_cache = os.path.join(cache_dir, "raw_features.npy")
        self.targets_cache = os.path.join(cache_dir, "raw_targets.npy")
        self.edge_index_cache = os.path.join(cache_dir, "edge_index.pt")
        self.edge_attr_cache = os.path.join(cache_dir, "edge_attr.pt")

        self.target_indices = []
        self.physics_indices = {}
        self.stations_meta = self._load_station_meta()

        if Transformer is not None:
            self.transformer = Transformer.from_crs(
                "EPSG:4326", "+proj=sinu +lon_0=0 +x_0=0 +y_0=0 +R=6371007.181 +units=m +no_defs", always_xy=True
            )
        else:
            self.transformer = None

    def _load_station_meta(self) -> pd.DataFrame:
        df = pd.read_csv(self.station_meta_path) if self.station_meta_path.lower().endswith('.csv') else pd.read_excel(self.station_meta_path, engine='openpyxl')
        df = df.rename(columns={"监测点编码": "station_id", "经度": "longitude", "纬度": "latitude"})[["station_id", "latitude", "longitude"]].copy()
        df["station_id"] = df["station_id"].astype(str).str.strip().str.upper()
        df["latitude"] = pd.to_numeric(df["latitude"], errors="coerce")
        df["longitude"] = pd.to_numeric(df["longitude"], errors="coerce")
        df = df.dropna(subset=["latitude", "longitude"])
        lon_min, lon_max = 113.5, 123.0
        lat_min, lat_max = 21.5, 38.5
        return df[(df["longitude"] >= lon_min) & (df["longitude"] <= lon_max) & (df["latitude"] >= lat_min) & (df["latitude"] <= lat_max)].reset_index(drop=True)

    def build_physics_geographic_graph(self, radius_km=100.0, max_neighbors=8):
        EARTH_RADIUS_M = 6371000.0
        coords = self.stations_meta[["latitude", "longitude"]].values
        if len(coords) < 2:
            raise ValueError("站点数不足，无法构建图结构。")

        from scipy.spatial import KDTree
        lat_r = np.radians(coords[:, 0])
        lon_r = np.radians(coords[:, 1])
        x = EARTH_RADIUS_M * np.cos(lat_r) * np.cos(lon_r)
        y = EARTH_RADIUS_M * np.cos(lat_r) * np.sin(lon_r)
        z = EARTH_RADIUS_M * np.sin(lat_r)
        xyz = np.stack([x, y, z], axis=1)
        tree = KDTree(xyz)
        edges_u, edges_v = [], []
        radius_m = radius_km * 1000.0
        for i in range(len(coords)):
            dists, ids = tree.query(xyz[i], k=min(len(coords), max_neighbors+1), distance_upper_bound=radius_m)
            for d, j in zip(dists, ids):
                if i == j or j >= len(coords): continue
                edges_u.append(i)
                edges_v.append(j)

        if not edges_u:
            raise ValueError(f"在 {radius_km}km 阈值下，没有构建出任何边！请调大 radius_km 阈值。")

        edges_u = np.array(edges_u)
        edges_v = np.array(edges_v)
        edge_index = torch.tensor(np.stack([edges_u, edges_v], axis=0), dtype=torch.long)

        dlat = lat_r[edges_v] - lat_r[edges_u]
        dlon = lon_r[edges_v] - lon_r[edges_u]
        a = np.sin(dlat/2)**2 + np.cos(lat_r[edges_u]) * np.cos(lat_r[edges_v]) * np.sin(dlon/2)**2
        dist_arr = EARTH_RADIUS_M * 2 * np.arctan2(np.sqrt(a), np.sqrt(np.clip(1-a, 0, None)))
        norm = np.sqrt(dlat**2 + dlon**2) + 1e-8
        edge_attr = torch.tensor(
            np.stack([dlon/norm, dlat/norm, dist_arr], axis=1), dtype=torch.float32
        )

        torch.save(edge_index, self.edge_index_cache)
        torch.save(edge_attr, self.edge_attr_cache)
        logger.info(f"图结构构建完成 (KD‑Tree): 阈值 {radius_km}km, 节点 {len(coords)}, 边数 {len(edges_u)}")
        return edge_index, edge_attr

    @staticmethod
    def _parse_one_csv(fp: str):
        try:
            df = pd.read_csv(fp, encoding="utf-8", low_memory=False)
        except UnicodeDecodeError:
            try:
                df = pd.read_csv(fp, encoding="gbk", low_memory=False)
            except Exception as e:
                logger.warning(f"解析失败 {fp}: {e}")
                return None
        except Exception as e:
            logger.warning(f"读取失败 {fp}: {e}")
            return None

        df.columns = [str(c).strip().lower() if str(c).strip().lower() in ['date', 'hour', 'type'] else str(c).strip().upper() for c in df.columns]
        if not {"date", "hour", "type"}.issubset(df.columns):
            return None

        df['type'] = df['type'].astype(str).str.strip().str.upper().replace({"PM2_5": "PM2.5"})
        df = df[df['type'].isin({"PM2.5", "PM10", "NO2", "SO2", "O3", "CO"})].copy()
        if df.empty: return None

        hour_num = pd.to_numeric(df["hour"], errors="coerce")
        df["time"] = pd.to_datetime(df["date"].astype(str), format="%Y%m%d", errors='coerce') + pd.to_timedelta(hour_num, unit="h")
        df = df.dropna(subset=["time"])

        station_cols = [c for c in df.columns if c.lower() not in {"date", "hour", "type", "time"} and not c.lower().startswith("unnamed")]
        if not station_cols: return None

        stacked = df[['time', 'type'] + station_cols].groupby(['time', 'type']).mean().stack()
        stacked.index.names = ['time', 'pollutant', 'station_id']
        return stacked.unstack(level='pollutant').astype(np.float32)

    def _load_station_observations(self) -> pd.DataFrame:
        all_csv_files = [fp for d in self.station_dirs if os.path.isdir(d) for fp in glob.glob(os.path.join(d, "*.csv"))]
        if not all_csv_files: return pd.DataFrame()

        max_workers = min(os.cpu_count() or 8, 16)
        all_frames = []
        batch_size = 500
        batches = [all_csv_files[i:i+batch_size] for i in range(0, len(all_csv_files), batch_size)]

        for batch_files in tqdm(batches, desc="解析观测数据（分批）"):
            with concurrent.futures.ProcessPoolExecutor(max_workers=max_workers, mp_context=mp.get_context('spawn')) as executor:
                results = executor.map(self._parse_one_csv, batch_files, chunksize=10)
                for res in results:
                    if res is not None and not res.empty:
                        all_frames.append(res)
            gc.collect()

        if not all_frames: return pd.DataFrame()
        obs_df = pd.concat(all_frames).sort_index()
        obs_df = obs_df[~obs_df.index.duplicated(keep='last')]
        return obs_df.astype(np.float32)

    def _load_era5_features(self) -> pd.DataFrame:
        nc_files = sorted(glob.glob(os.path.join(self.era5_dir, "*.nc")))
        if not nc_files: return pd.DataFrame()

        try:
            ds = xr.open_mfdataset(nc_files, engine="h5netcdf", combine="by_coords", parallel=False, chunks={"latitude": 10, "longitude": 10})
        except Exception as e:
            logger.error(f"ERA5 打开失败: {e}")
            return pd.DataFrame()

        time_coord = "valid_time" if "valid_time" in ds.coords else "time"
        if time_coord not in ds.coords: return pd.DataFrame()

        ds = ds.assign_coords({time_coord: pd.to_datetime(ds[time_coord].values) + timedelta(hours=8)})
        required_vars = ["t2m", "d2m", "u10", "v10", "tp"]

        lats = xr.DataArray(self.stations_meta["latitude"].values, dims="station")
        lons = xr.DataArray(self.stations_meta["longitude"].values, dims="station")

        years = np.unique(pd.to_datetime(ds[time_coord].values).year)
        yearly_frames = []

        for year in tqdm(years, desc="按年计算 ERA5 物理场"):
            try:
                sub_ds = ds[required_vars].sel({time_coord: str(year)}).sel(latitude=lats, longitude=lons, method="nearest").compute()
                if len(sub_ds[time_coord]) == 0: continue

                u_sq = sub_ds["u10"]**2 + sub_ds["v10"]**2 + 1e-4
                t_celsius = sub_ds["t2m"] - 273.15
                rib = (9.81 * 10.0 * (t_celsius - (t_celsius - 0.5))) / (sub_ds["t2m"] * u_sq)
                rib = xr.where(np.isfinite(rib), rib, 0.0)
                rib = rib.clip(-1.0, 0.19)
                zeta = xr.where(rib > 0, rib / (1 - 5 * rib), rib)
                zeta = zeta.clip(-2.0, 2.0)
                phi_h = xr.where(zeta > 0, 1 + 5 * zeta, (1 - 16 * zeta)**(-0.5))
                phi_h = phi_h.clip(0.1, 20.0)
                u_star = np.sqrt(0.0015 * u_sq)
                k_z = (0.4 * 10.0 * u_star) / phi_h
                k_z = k_z.clip(0.01, 50.0)
                k_z = xr.where(np.isfinite(k_z), k_z, 1.0)

                era_np = sub_ds.assign(
                    TEMP_C=t_celsius, DEW_C=sub_ds["d2m"] - 273.15, WIND_U=sub_ds["u10"],
                    WIND_V=sub_ds["v10"], TP_MM=sub_ds["tp"] * 1000.0, K_Z=k_z
                ).astype(np.float32)

                sids = self.stations_meta["station_id"].astype(str).values
                times_bj = era_np[time_coord].values
                era5_cols = ['TEMP_C', 'DEW_C', 'WIND_U', 'WIND_V', 'TP_MM', 'K_Z']

                df_year = pd.DataFrame({
                    "time": np.repeat(times_bj, len(sids)),
                    "station_id": np.tile(sids, len(times_bj)),
                    **{f: era_np[f].values.ravel() for f in era5_cols}
                }).set_index(["time", "station_id"])

                yearly_frames.append(df_year)
                del sub_ds, era_np, df_year
                gc.collect()
            except Exception as e:
                logger.warning(f"ERA5 年度处理失败 {year}: {e}")

        try: ds.close()
        except Exception: pass
        return pd.concat(yearly_frames).sort_index() if yearly_frames else pd.DataFrame()

    @staticmethod
    def _process_single_h8_static(args):
        fp, sids, lat_indices, lon_indices = args
        try:
            if not os.path.exists(fp) or os.path.getsize(fp) < 10240:
                return None

            try:
                ds = xr.open_dataset(fp, engine="h5netcdf", decode_timedelta=False, decode_coords=False)
            except Exception:
                try:
                    ds = xr.open_dataset(fp, engine="netcdf4", decode_timedelta=False, decode_coords=False)
                except Exception:
                    ds = xr.open_dataset(fp, decode_timedelta=False, decode_coords=False)

            with ds:
                lat_idx_da = xr.DataArray(lat_indices, dims="station")
                lon_idx_da = xr.DataArray(lon_indices, dims="station")
                station_ds = ds[['AOT_Merged', 'AE_Merged', 'Hour']].isel(latitude=lat_idx_da, longitude=lon_idx_da).compute()

                hour_val = station_ds["Hour"].values
                try:
                    hour_arr = np.asarray(hour_val, dtype=np.float32)
                except Exception:
                    hour_arr = np.full(len(sids), np.nan, dtype=np.float32)

                if hour_arr.ndim == 0:
                    hour_arr = np.full(len(sids), float(hour_arr), dtype=np.float32)
                elif hour_arr.size == 1:
                    hour_arr = np.full(len(sids), float(hour_arr.ravel()[0]), dtype=np.float32)
                else:
                    hour_arr = hour_arr.ravel().astype(np.float32)

                if 'time' in ds.variables or 'time' in ds.coords:
                    t_val = ds['time'].values if 'time' in ds.variables else ds.coords['time'].values
                    t = pd.to_datetime(t_val[0] if getattr(t_val, 'ndim', 0) > 0 else t_val) + pd.Timedelta(hours=8)
                else:
                    return None

                aot = station_ds["AOT_Merged"].values.ravel().astype(np.float32)
                ae = station_ds["AE_Merged"].values.ravel().astype(np.float32)

                n = len(sids)
                if hour_arr.size != n: hour_arr = np.full(n, hour_arr[0] if hour_arr.size > 0 else np.nan, dtype=np.float32)
                if aot.size != n: aot = np.full(n, np.nan, dtype=np.float32)
                if ae.size != n: ae = np.full(n, np.nan, dtype=np.float32)

                return pd.DataFrame({"time": np.repeat(t, len(sids)), "station_id": sids, "H8_AOT_Merged": aot, "H8_AE_Merged": ae, "H8_Hour_Float": hour_arr})
        except Exception as e:
            logger.warning(f"Himawari 解析失败 {fp}: {e}")
            return None

    def _load_himawari_features(self) -> pd.DataFrame:
        nc_files = []
        for root, dirs, files in os.walk(self.himawari_dir, followlinks=True):
            dirs[:] = [d for d in dirs if d.lower() not in ['daily', 'monthly']]
            for file in files:
                if file.lower().endswith('.nc') or file.lower().endswith('.nc4'):
                    nc_files.append(os.path.join(root, file))
        nc_files = sorted(nc_files)
        if not nc_files: return pd.DataFrame()

        try:
            with xr.open_dataset(nc_files[0], engine="h5netcdf", decode_timedelta=False) as ds:
                h8_lats, h8_lons = ds.latitude.values, ds.longitude.values
        except Exception as e:
            logger.error(f"Himawari 格点读取失败: {e}")
            return pd.DataFrame()

        lat_indices = [np.abs(h8_lats - lat).argmin() for lat in self.stations_meta["latitude"].values]
        lon_indices = [np.abs(h8_lons - lon).argmin() for lon in self.stations_meta["longitude"].values]
        sids = self.stations_meta["station_id"].astype(str).values

        task_args = [(fp, sids, lat_indices, lon_indices) for fp in nc_files]
        merged_dfs = []
        chunk_size = 500
        max_workers = min(os.cpu_count() or 8, 20)

        for i in tqdm(range(0, len(task_args), chunk_size), desc="解析葵花8号 (分块)"):
            batch = task_args[i:i+chunk_size]
            with concurrent.futures.ProcessPoolExecutor(max_workers=max_workers) as executor:
                results = executor.map(self._process_single_h8_static, batch, chunksize=10)
                batch_dfs = []
                for res in results:
                    if res is not None and not res.empty:
                        batch_dfs.append(res)
                if batch_dfs:
                    merged_dfs.append(pd.concat(batch_dfs).astype(np.float32))
                    gc.collect()

        if not merged_dfs: return pd.DataFrame()
        return pd.concat(merged_dfs).set_index(["time", "station_id"]).sort_index()

    @staticmethod
    def _parse_one_modis_hdf(args):
        fp, station_info = args
        records = []
        try:
            from pyhdf.SD import SD, SDC
            hdf = SD(fp, SDC.READ)

            attr_dict = hdf.attributes()
            orbit_times_str = attr_dict.get('Orbit_time_stamp', '')
            matches = re.findall(r'(\d{11})[A-Za-z]?', orbit_times_str)
            timestamps_bjt = []
            for t_str in matches:
                dt_utc = datetime.strptime(t_str, "%Y%j%H%M")
                dt_bjt = dt_utc + timedelta(hours=8)
                if dt_bjt.minute > 0 or dt_bjt.second > 0:
                    dt_bjt_hourly = dt_bjt.replace(minute=0, second=0, microsecond=0) + timedelta(hours=1)
                else:
                    dt_bjt_hourly = dt_bjt
                timestamps_bjt.append(dt_bjt_hourly)

            sids = station_info['sids']
            rows = station_info['rows']
            cols = station_info['cols']

            sds_047 = hdf.select('Optical_Depth_047')
            aod_047_data = sds_047.get().astype(np.float32)
            sds_047.endaccess()

            sds_055 = hdf.select('Optical_Depth_055')
            aod_055_data = sds_055.get().astype(np.float32)
            sds_055.endaccess()

            sds_qa = hdf.select('AOD_QA')
            qa_data = sds_qa.get().astype(np.uint16)
            sds_qa.endaccess()
            hdf.end()

            is_clear = (qa_data & 7) == 1
            aod_047_data = np.where((aod_047_data > 0) & is_clear, aod_047_data * 0.001, np.nan)
            aod_055_data = np.where((aod_055_data > 0) & is_clear, aod_055_data * 0.001, np.nan)

            num_orbits = min(len(timestamps_bjt), aod_047_data.shape[0])
            for orbit_idx in range(num_orbits):
                current_time = timestamps_bjt[orbit_idx]
                val_047 = aod_047_data[orbit_idx, rows, cols]
                val_055 = aod_055_data[orbit_idx, rows, cols]
                for sid, v047, v055 in zip(sids, val_047, val_055):
                    if not np.isnan(v047) or not np.isnan(v055):
                        records.append((current_time, sid, v047, v055))
            if not records: return pd.DataFrame()
            df = pd.DataFrame(records, columns=['time', 'station_id', 'AOD_047', 'AOD_055'])
            return df.groupby(['time', 'station_id']).mean().reset_index()
        except Exception as e:
            logger.warning(f"MODIS 解析失败 {fp}: {e}")
            return pd.DataFrame()

    def _load_modis_features(self) -> pd.DataFrame:
        if self.transformer is None: return pd.DataFrame()
        hdf_files = sorted(glob.glob(os.path.join(self.modis_dir, "**/*.hdf"), recursive=True))
        if not hdf_files: return pd.DataFrame()

        sids = self.stations_meta['station_id'].values
        lons = self.stations_meta['longitude'].values
        lats = self.stations_meta['latitude'].values
        sinu_x, sinu_y = self.transformer.transform(lons, lats)

        TILE_SIZE, PIXEL_SIZE = 1111950.5196666666, 1111950.5196666666 / 1200.0
        req_h = np.floor((sinu_x + 20015109.354) / TILE_SIZE).astype(int)
        req_v = np.floor((10007554.677 - sinu_y) / TILE_SIZE).astype(int)

        tile_to_stations = {}
        for h, v in set(zip(req_h, req_v)):
            mask = (req_h == h) & (req_v == v)
            if not mask.any(): continue
            cols = np.floor((sinu_x[mask] - (h * TILE_SIZE - 20015109.354)) / PIXEL_SIZE).astype(int)
            rows = np.floor(((10007554.677 - v * TILE_SIZE) - sinu_y[mask]) / PIXEL_SIZE).astype(int)
            valid_p = (cols >= 0) & (cols < 1200) & (rows >= 0) & (rows < 1200)
            tile_to_stations[f"h{h:02d}v{v:02d}"] = {
                'sids': sids[mask][valid_p],
                'rows': rows[valid_p],
                'cols': cols[valid_p]
            }

        tasks = [(fp, tile_to_stations[m.group(0)]) for fp in hdf_files if (m := re.search(r'h(\d{2})v(\d{2})', os.path.basename(fp))) and m.group(0) in tile_to_stations]
        if not tasks: return pd.DataFrame()

        dfs = []
        worker_count = min(os.cpu_count() or 4, 8)
        for i in tqdm(range(0, len(tasks), 100), desc="MODIS 提取（分批）"):
            batch = tasks[i:i+100]
            with concurrent.futures.ProcessPoolExecutor(max_workers=worker_count, mp_context=mp.get_context('spawn')) as executor:
                futures = {executor.submit(self.__class__._parse_one_modis_hdf, t): t for t in batch}
                for future in concurrent.futures.as_completed(futures):
                    try:
                        res_df = future.result()
                        if not res_df.empty: dfs.append(res_df)
                    except Exception as e:
                        logger.warning(f"MODIS 任务失败: {e}")

        if not dfs: return pd.DataFrame()
        modis_df = pd.concat(dfs, ignore_index=True)
        return modis_df.groupby(['time', 'station_id']).mean().reset_index().set_index(['time', 'station_id']).astype(np.float32)

    def process_and_cache(self, target_cols: list):
        meta_cache_path = os.path.join(self.cache_dir, "feature_meta.json")

        if os.path.exists(self.features_cache) and os.path.exists(self.targets_cache) and os.path.exists(meta_cache_path):
            with open(meta_cache_path, 'r') as f: feature_cols = json.load(f)
            self.target_indices = [feature_cols.index(tc) for tc in target_cols]
            self.physics_indices = {
                'u': feature_cols.index('WIND_U'),
                'v': feature_cols.index('WIND_V'),
                'k': feature_cols.index('K_Z')
            }
            return

        full_df = self._load_station_observations()
        if full_df.empty: raise RuntimeError("站点观测数据为空，无法继续。")

        era5_df = self._load_era5_features()
        if not era5_df.empty: full_df = full_df.join(era5_df, how="left")

        himawari_df = self._load_himawari_features()
        if not himawari_df.empty: full_df = full_df.join(himawari_df, how="left")

        modis_df = self._load_modis_features()
        if not modis_df.empty: full_df = full_df.join(modis_df, how="left")

        min_time, max_time = full_df.index.get_level_values("time").min(), full_df.index.get_level_values("time").max()
        continuous_times = pd.date_range(start=min_time, end=max_time, freq='h')

        valid_stations = np.sort(np.intersect1d(full_df.index.get_level_values("station_id").unique().astype(str), self.stations_meta["station_id"].astype(str).values))
        if len(valid_stations) == 0: raise RuntimeError("没有有效站点可用于训练。")

        self.stations_meta = self.stations_meta.set_index("station_id").loc[valid_stations].reset_index()
        full_idx = pd.MultiIndex.from_product([continuous_times, valid_stations], names=["time", "station_id"])
        full_df = full_df.reindex(full_idx)

        float64_cols = full_df.select_dtypes(include=['float64']).columns
        if len(float64_cols) > 0: full_df[float64_cols] = full_df[float64_cols].astype(np.float32)

        cols_to_ffill = target_cols + ['TEMP_C', 'DEW_C', 'WIND_U', 'WIND_V', 'TP_MM', 'K_Z']
        available_cols_to_ffill = [c for c in cols_to_ffill if c in full_df.columns]
        if available_cols_to_ffill:
            full_df[available_cols_to_ffill] = full_df.groupby(level="station_id")[available_cols_to_ffill].transform(lambda x: x.ffill(limit=3))

        temp_df = full_df.reset_index()

        temp_df['TIME_MONTH'] = temp_df['time'].dt.month
        temp_df['TIME_HOUR'] = temp_df['time'].dt.hour
        temp_df['DOY'] = temp_df['time'].dt.dayofyear
        temp_df['TIME_DOY_SIN'] = np.sin(2 * np.pi * temp_df['DOY'] / 365.25).astype(np.float32)
        temp_df['TIME_DOY_COS'] = np.cos(2 * np.pi * temp_df['DOY'] / 365.25).astype(np.float32)
        temp_df['TIME_MONTH_SIN'] = np.sin(2 * np.pi * temp_df['TIME_MONTH'] / 12.0).astype(np.float32)
        temp_df['TIME_MONTH_COS'] = np.cos(2 * np.pi * temp_df['TIME_MONTH'] / 12.0).astype(np.float32)
        temp_df = temp_df.drop(columns=['DOY'])

        aod_columns_to_impute = ['H8_AOT_Merged', 'H8_AE_Merged', 'AOD_047', 'AOD_055']
        tree_features = [c for c in temp_df.columns if c not in aod_columns_to_impute + ['time', 'station_id']]

        train_end_idx = int(len(continuous_times) * 0.7)
        train_cutoff_date = continuous_times[train_end_idx]

        if lgb is not None:
            for aod_col in aod_columns_to_impute:
                if aod_col not in temp_df.columns: continue
                train_mask = temp_df[aod_col].notnull() & (temp_df['time'] < train_cutoff_date)
                if train_mask.sum() > 100:
                    train_indices = temp_df[train_mask].index
                    if len(train_indices) > 1000000:
                        train_indices = np.random.choice(train_indices, size=1000000, replace=False)
                    X_train = temp_df.loc[train_indices, tree_features]
                    y_train = temp_df.loc[train_indices, aod_col]
                    lgb_model = lgb.LGBMRegressor(n_estimators=100, random_state=42, n_jobs=-1, verbose=-1)
                    lgb_model.fit(X_train, y_train)
                    pred_mask = temp_df[aod_col].isnull()
                    if pred_mask.sum() > 0:
                        temp_df.loc[pred_mask, aod_col] = lgb_model.predict(temp_df.loc[pred_mask, tree_features]).astype(np.float32)
                    del lgb_model, X_train, y_train, train_indices
                    gc.collect()

        temp_df = temp_df.set_index(['time', 'station_id'])
        for col in aod_columns_to_impute:
            if col in temp_df.columns: full_df[col] = temp_df[col]

        time_encode_cols = ['TIME_MONTH', 'TIME_HOUR', 'TIME_DOY_SIN', 'TIME_DOY_COS', 'TIME_MONTH_SIN', 'TIME_MONTH_COS']
        for col in time_encode_cols:
            if col in temp_df.columns:
                full_df[col] = temp_df[col]

        meteorological_cols = ['TEMP_C', 'DEW_C', 'WIND_U', 'WIND_V', 'TP_MM', 'K_Z']
        for col in meteorological_cols:
            if col in full_df.columns:
                full_df[col] = full_df.groupby(level='station_id')[col].transform(lambda x: x.interpolate(limit_direction='both', limit=6))

        other_cols = [c for c in full_df.columns if c not in meteorological_cols + target_cols]
        mean_vals = full_df[other_cols].mean()
        full_df[other_cols] = full_df[other_cols].fillna(mean_vals).fillna(0.0)

        for tc in target_cols:
            if tc in full_df.columns:
                full_df[tc] = full_df[tc].fillna(0.0).clip(lower=0.0)

        for mc in meteorological_cols:
            if mc in full_df.columns:
                col_mean = full_df[mc].mean()
                if not np.isfinite(col_mean):
                    col_mean = 0.0
                full_df[mc] = full_df[mc].fillna(col_mean).fillna(0.0)

        if 'latitude' in full_df.columns: full_df = full_df.drop(columns=['latitude', 'longitude'], errors="ignore")

        feature_cols = target_cols + [c for c in full_df.columns if c not in target_cols]

        raw_matrix = full_df[feature_cols].to_numpy(dtype=np.float32).reshape(
            len(continuous_times), len(valid_stations), len(feature_cols)
        )

        nan_count = np.isnan(raw_matrix).sum()
        inf_count = np.isinf(raw_matrix).sum()
        if nan_count > 0 or inf_count > 0:
            logger.warning(f"raw_matrix 残余异常值: NaN={nan_count}, Inf={inf_count}, 已用 0 填充")
            raw_matrix = np.nan_to_num(raw_matrix, nan=0.0, posinf=0.0, neginf=0.0)

        self.target_indices = [feature_cols.index(tc) for tc in target_cols]
        self.physics_indices = {
            'u': feature_cols.index('WIND_U'),
            'v': feature_cols.index('WIND_V'),
            'k': feature_cols.index('K_Z')
        }

        np.save(self.features_cache, raw_matrix)
        np.save(self.targets_cache, raw_matrix[:, :, self.target_indices])
        with open(meta_cache_path, 'w') as f: json.dump(feature_cols, f)
        logger.info("数据缓存及特征工程完成。")


