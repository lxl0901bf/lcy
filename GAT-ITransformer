# 4. 训练核心管道
# ==========================================
class ForecastingPipeline:
    def __init__(self, model, config, edge_index, edge_attr_static, physics_idx):
        self.model = model.to(config['device'])
        self.config = config
        self.device = config['device']
        self.edge_index = edge_index.to(self.device)
        self.edge_attr_static = edge_attr_static.to(self.device)
        self.physics_idx = physics_idx

        self.optimizer = torch.optim.AdamW(
            self.model.parameters(), lr=config['lr'], weight_decay=1e-2
        )

        self.use_amp = (self.device.type == 'cuda')
        self.amp_dtype = torch.bfloat16
        self.scaler = torch.amp.GradScaler('cuda', enabled=False)

        self.scheduler = ReduceLROnPlateau(
            self.optimizer, mode='min', factor=0.5, patience=3, min_lr=1e-6
        )

        self.warmup_steps = int(config.get('warmup_steps', 1000))
        def warmup_lambda(step):
            if step < self.warmup_steps:
                return float(step + 1) / float(self.warmup_steps)
            return 1.0
        self.warmup_scheduler = LambdaLR(self.optimizer, lr_lambda=warmup_lambda)
        self.warmup_step_count = 0

        self.var_weights = torch.tensor(
            [3.0, 2.0, 1.0, 1.0, 1.0, 0.5], device=self.device
        ).view(1, 1, 1, -1)

        self.ema = ExponentialMovingAverage(self.model, decay=0.999)
        self.nan_skip_count = 0

        n_steps = self.model.refinement_steps + 1
        weights = torch.linspace(0.5, 1.0, n_steps, device=self.device)
        self.refine_weights = (weights / weights.sum()).tolist()
        logger.info(f"Refinement 深度监督权重: {[f'{w:.3f}' for w in self.refine_weights]}")

    def _compute_pde_penalty(self, traj, raw_last_x):
        """弱物理约束: 平流-扩散方程的 1 小时差分残差"""
        traj = traj.float()
        raw_last_x = raw_last_x.float()
        edge_attr_static = self.edge_attr_static.float()

        B, N, pred_len, _ = traj.shape
        u   = torch.clamp(raw_last_x[:, :, self.physics_idx['u']], -30.0, 30.0)
        v   = torch.clamp(raw_last_x[:, :, self.physics_idx['v']], -30.0, 30.0)
        k_z = torch.clamp(raw_last_x[:, :, self.physics_idx['k']], 0.01, 50.0)

        edges_u, edges_v = self.edge_index[0], self.edge_index[1]
        dx = edge_attr_static[:, 0]
        dy = edge_attr_static[:, 1]
        dist = torch.clamp(edge_attr_static[:, 2], min=1000.0)

        v_proj = u[:, edges_u] * dx + v[:, edges_u] * dy
        v_proj_h = torch.clamp(v_proj, -30.0, 30.0)
        k_z_h = k_z[:, edges_u]

        T_limit = min(pred_len - 1, 24)
        traj_clamped = torch.clamp(traj, -100.0, 5000.0)
        C_t    = traj_clamped[:, :, :T_limit, :]
        C_next = traj_clamped[:, :, 1:T_limit+1, :]

        dC_dt_25 = (C_next[..., 0] - C_t[..., 0]) / 3600.0
        dC_dt_10 = (C_next[..., 1] - C_t[..., 1]) / 3600.0

        C_u_25 = C_t[:, edges_u, :, 0]
        C_v_25 = C_t[:, edges_v, :, 0]
        C_u_10 = C_t[:, edges_u, :, 1]
        C_v_10 = C_t[:, edges_v, :, 1]

        v_proj_h_exp = v_proj_h.unsqueeze(-1)
        k_z_h_exp = k_z_h.unsqueeze(-1)
        dist_exp = dist.unsqueeze(0).unsqueeze(-1)

        flux_adv_25  = torch.where(v_proj_h_exp > 0, (v_proj_h_exp / dist_exp) * C_u_25, (v_proj_h_exp / dist_exp) * C_v_25)
        flux_adv_10  = torch.where(v_proj_h_exp > 0, (v_proj_h_exp / dist_exp) * C_u_10, (v_proj_h_exp / dist_exp) * C_v_10)
        flux_diff_25 = (k_z_h_exp / (dist_exp ** 2)) * (C_u_25 - C_v_25)
        flux_diff_10 = (k_z_h_exp / (dist_exp ** 2)) * (C_u_10 - C_v_10)

        total_flux_25 = flux_adv_25 + flux_diff_25
        total_flux_10 = flux_adv_10 + flux_diff_10

        net_flux_25 = torch.zeros_like(dC_dt_25)
        net_flux_10 = torch.zeros_like(dC_dt_10)
        edges_v_expand = edges_v.view(1, -1, 1).expand(B, -1, T_limit)
        edges_u_expand = edges_u.view(1, -1, 1).expand(B, -1, T_limit)

        net_flux_25.scatter_add_(1, edges_v_expand, total_flux_25)
        net_flux_10.scatter_add_(1, edges_v_expand, total_flux_10)
        net_flux_25.scatter_add_(1, edges_u_expand, -total_flux_25)
        net_flux_10.scatter_add_(1, edges_u_expand, -total_flux_10)

        decay_factor = torch.exp(
            -torch.arange(T_limit, device=traj.device, dtype=torch.float32) / 6.0
        ).view(1, 1, T_limit)
        node_penalties_25 = (torch.abs(dC_dt_25 - net_flux_25) * decay_factor).sum(dim=-1)
        node_penalties_10 = (torch.abs(dC_dt_10 - net_flux_10) * decay_factor).sum(dim=-1)
        avg_25 = node_penalties_25 / max(1, T_limit)
        avg_10 = node_penalties_10 / max(1, T_limit)
        return torch.stack([avg_25, avg_10], dim=-1)

    def _check_finite(self, *tensors):
        for t in tensors:
            if not torch.isfinite(t).all():
                return False
        return True

    def _train_step(self, batch_x, batch_y, batch_mu, batch_std, raw_last_x):
        if not self._check_finite(batch_x, batch_y, batch_mu, batch_std, raw_last_x):
            self.nan_skip_count += 1
            logger.warning(f"输入含 NaN/Inf，跳过该 step (累计 {self.nan_skip_count})")
            return float('nan')

        self.optimizer.zero_grad(set_to_none=True)

        with torch.amp.autocast('cuda', enabled=self.use_amp, dtype=self.amp_dtype):
            all_preds = self.model(
                batch_x, self.edge_index, self.edge_attr_static, return_all_steps=True
            )

            loss_data = torch.tensor(0.0, device=self.device)
            for w, pred_k in zip(self.refine_weights, all_preds):
                step_loss = (F.huber_loss(pred_k, batch_y, reduction='none') * self.var_weights).mean()
                loss_data = loss_data + w * step_loss

            final_pred = all_preds[-1]

        mu_exp  = batch_mu.unsqueeze(1).float()
        std_exp = batch_std.unsqueeze(1).float()
        final_pred_real = final_pred.float() * std_exp + mu_exp
        final_pred_real = torch.clamp(final_pred_real, -100.0, 5000.0)

        loss_nonneg = F.relu(-final_pred_real).mean() * self.config.get('lambda_nonneg', 0.001)

        phys_warmup = min(1.0, float(self.warmup_step_count) / max(1, self.warmup_steps))
        lambda_phys = self.config.get('lambda_phys', 0.02) * phys_warmup
        if lambda_phys > 0:
            phys_penalty_raw = self._compute_pde_penalty(
                final_pred_real.permute(0, 2, 1, 3),
                raw_last_x
            )
            std_25_10 = torch.clamp(batch_std[:, :, :2].float(), min=1.0)
            loss_phys = (phys_penalty_raw / std_25_10).mean() * lambda_phys
        else:
            loss_phys = torch.tensor(0.0, device=self.device)

        loss = loss_data + loss_phys + loss_nonneg

        if not torch.isfinite(loss):
            self.nan_skip_count += 1
            logger.warning(
                f"Loss NaN/Inf (data={loss_data.item():.4f}, "
                f"phys={loss_phys.item():.4f}, nonneg={loss_nonneg.item():.4f})，跳过 (累计 {self.nan_skip_count})"
            )
            self.optimizer.zero_grad(set_to_none=True)
            return float('nan')

        loss.backward()

        grad_finite = True
        for p in self.model.parameters():
            if p.grad is not None and not torch.isfinite(p.grad).all():
                grad_finite = False
                break
        if not grad_finite:
            self.nan_skip_count += 1
            logger.warning(f"梯度 NaN/Inf，跳过 step (累计 {self.nan_skip_count})")
            self.optimizer.zero_grad(set_to_none=True)
            return float('nan')

        torch.nn.utils.clip_grad_norm_(self.model.parameters(), max_norm=1.0)
        self.optimizer.step()
        self.warmup_scheduler.step()
        self.warmup_step_count += 1
        self.ema.update()
        return loss.item()

    def evaluate_rmse(self, dataloader):
        self.model.eval()
        total_se_overall  = 0.0
        sum_y_overall     = 0.0
        sum_y2_overall    = 0.0
        total_count_overall = 0
        total_phys_loss   = 0.0

        num_vars = len(self.config['target_columns'])
        total_se_vars  = torch.zeros(num_vars, device=self.device)
        sum_y_vars     = torch.zeros(num_vars, device=self.device)
        sum_y2_vars    = torch.zeros(num_vars, device=self.device)

        with torch.no_grad():
            for x, y, mu, std, raw in dataloader:
                x, y    = x.to(self.device), y.to(self.device)
                mu, std = mu.to(self.device), std.to(self.device)
                raw     = raw.to(self.device)

                preds = self.model(x, self.edge_index, self.edge_attr_static, return_all_steps=False)

                mu_exp  = mu.unsqueeze(1)
                std_exp = std.unsqueeze(1)

                preds_real = preds.float() * std_exp + mu_exp
                y_real     = y.float()     * std_exp + mu_exp
                preds_real = torch.clamp(preds_real, -100.0, 5000.0)

                se = F.mse_loss(preds_real, y_real, reduction='none')

                phys_penalty_raw = self._compute_pde_penalty(
                    preds_real.permute(0, 2, 1, 3), raw
                )
                total_phys_loss += phys_penalty_raw.mean().item() * x.size(0)

                total_se_overall  += se.sum().item()
                sum_y_overall     += y_real.sum().item()
                sum_y2_overall    += (y_real ** 2).sum().item()
                total_count_overall += se.numel()

                total_se_vars  += se.sum(dim=(0, 1, 2))
                sum_y_vars     += y_real.sum(dim=(0, 1, 2))
                sum_y2_vars    += (y_real ** 2).sum(dim=(0, 1, 2))

        if total_count_overall == 0:
            return float("nan"), {}, float("nan"), {}, 0.0

        total_count_vars = total_count_overall / num_vars
        overall_rmse = float(np.sqrt(total_se_overall / total_count_overall))
        var_rmses_tensor = torch.sqrt(total_se_vars / total_count_vars).cpu().numpy()

        ss_tot_overall = sum_y2_overall - (sum_y_overall ** 2) / total_count_overall
        overall_r2 = float(1.0 - (total_se_overall / ss_tot_overall)) if ss_tot_overall != 0 else 0.0

        ss_tot_vars = sum_y2_vars - (sum_y_vars ** 2) / total_count_vars
        var_r2_tensor = 1.0 - (total_se_vars / ss_tot_vars)
        var_r2_tensor = torch.where(ss_tot_vars == 0, torch.zeros_like(var_r2_tensor), var_r2_tensor).cpu().numpy()

        var_rmses = {col: float(rmse) for col, rmse in zip(self.config['target_columns'], var_rmses_tensor)}
        var_r2s   = {col: float(r2)   for col, r2   in zip(self.config['target_columns'], var_r2_tensor)}
        avg_phys_loss = total_phys_loss / len(dataloader.dataset)

        return overall_rmse, var_rmses, overall_r2, var_r2s, avg_phys_loss

    def train_and_evaluate(self, train_loader, val_loader, save_dir="./save_models"):
        os.makedirs(save_dir, exist_ok=True)
        os.makedirs("./logs", exist_ok=True)

        best_val_rmse = float('inf')
        history = {'train_loss': [], 'val_rmse': [], 'val_r2': [], 'val_phys': []}

        start_epoch = 0
        ckpt_path = os.path.join(save_dir, "ST_GCN_latest_checkpoint.pth")
        val_check_steps = 2000
        patience = 8
        early_stop_counter = 0

        if os.path.exists(ckpt_path):
            logger.info(f"恢复检查点: {ckpt_path}")
            try:
                checkpoint = torch.load(ckpt_path, map_location=self.device, weights_only=False)
                self.model.load_state_dict(checkpoint['model_state_dict'], strict=False)
                if 'optimizer_state_dict' in checkpoint:
                    self.optimizer.load_state_dict(checkpoint['optimizer_state_dict'])
                if 'scheduler_state_dict' in checkpoint:
                    self.scheduler.load_state_dict(checkpoint['scheduler_state_dict'])
                if 'ema_shadow' in checkpoint:
                    self.ema.load_state_dict(checkpoint['ema_shadow'])
                if 'warmup_step_count' in checkpoint:
                    self.warmup_step_count = checkpoint['warmup_step_count']
                start_epoch = int(checkpoint.get('epoch', -1)) + 1
                if 'best_val_rmse' in checkpoint:
                    best_val_rmse = checkpoint['best_val_rmse']
            except Exception as e:
                logger.warning(f"检查点加载失败: {e}，从头开始")

        if start_epoch >= self.config['epochs']:
            logger.info("已完成所有 epoch，跳过训练阶段。")
        else:
            logger.info("=== 开始训练 ===")
            for epoch in range(start_epoch, self.config['epochs']):
                self.model.train()
                epoch_loss = 0.0
                valid_steps = 0

                pbar = tqdm(
                    train_loader,
                    desc=f"Epoch {epoch+1}/{self.config['epochs']}",
                    mininterval=10.0
                )
                for step, (x, y, mu, std, raw) in enumerate(pbar):
                    loss = self._train_step(
                        x.to(self.device), y.to(self.device),
                        mu.to(self.device), std.to(self.device),
                        raw.to(self.device)
                    )
                    if not (np.isnan(loss) or np.isinf(loss)):
                        epoch_loss += loss
                        valid_steps += 1
                    pbar.set_postfix({
                        'Loss': f"{loss:.4f}",
                        'NaN_skip': self.nan_skip_count
                    })
                    if (step + 1) % val_check_steps == 0:
                        torch.save({
                            'epoch': epoch,
                            'step': step,
                            'model_state_dict': self.model.state_dict(),
                            'optimizer_state_dict': self.optimizer.state_dict(),
                            'scheduler_state_dict': self.scheduler.state_dict(),
                            'ema_shadow': self.ema.state_dict(),
                            'warmup_step_count': self.warmup_step_count,
                            'best_val_rmse': best_val_rmse,
                        }, ckpt_path)

                avg_loss = epoch_loss / max(1, valid_steps)

                self.ema.apply_shadow()
                val_rmse_overall, val_rmse_vars, val_r2_overall, val_r2_vars, val_phys = \
                    self.evaluate_rmse(val_loader)
                self.ema.restore()

                self.scheduler.step(val_rmse_overall)

                history['train_loss'].append(avg_loss)
                history['val_rmse'].append(val_rmse_overall)
                history['val_r2'].append(val_r2_overall)
                history['val_phys'].append(val_phys)

                logger.info(
                    f"Epoch {epoch+1} | Loss: {avg_loss:.4f} | "
                    f"RMSE: {val_rmse_overall:.4f} | R2: {val_r2_overall:.4f} | "
                    f"Phys: {val_phys:.4f} | NaN_skip: {self.nan_skip_count}"
                )
                for k in val_rmse_vars:
                    logger.info(f"  {k}: RMSE={val_rmse_vars[k]:.2f}, R2={val_r2_vars[k]:.3f}")

                if val_rmse_overall < best_val_rmse:
                    best_val_rmse = val_rmse_overall
                    early_stop_counter = 0
                    torch.save({
                        'epoch': epoch,
                        'model_state_dict': self.model.state_dict(),
                        'optimizer_state_dict': self.optimizer.state_dict(),
                        'best_val_rmse': best_val_rmse,
                        'ema_shadow': self.ema.state_dict(),
                    }, os.path.join(save_dir, "ST_GCN_best.pth"))
                    logger.info(f"🏆 最优模型已保存 (RMSE={best_val_rmse:.4f})")
                else:
                    early_stop_counter += 1
                    if early_stop_counter >= patience:
                        logger.info(f"早停触发 (patience={patience})")
                        break

            torch.save({
                'epoch': self.config['epochs'],
                'completion': True,
                'best_val_rmse': best_val_rmse,
            }, ckpt_path)

        self.plot_training_curves(history)
        return history

    def plot_training_curves(self, history, save_dir="./logs"):
        os.makedirs(save_dir, exist_ok=True)
        if len(history.get('train_loss', [])) == 0:
            logger.info("无训练历史可绘制。")
            return

        plt.figure(figsize=(14, 5))
        plt.subplot(1, 2, 1)
        ax1, ax2 = plt.gca(), plt.gca().twinx()
        ax1.plot(history['train_loss'], 'b-', label='Train Loss')
        ax2.plot(history['val_rmse'],   'r--', label='Val RMSE')
        ax1.set_xlabel('Epochs')
        ax1.set_ylabel('Loss', color='b')
        ax2.set_ylabel('RMSE', color='r')
        plt.title('Loss & RMSE')
        ax1.legend(loc='upper left')
        ax2.legend(loc='upper right')

        plt.subplot(1, 2, 2)
        ax1, ax2 = plt.gca(), plt.gca().twinx()
        ax1.plot(history['val_r2'], 'g-', label='Val R²')
        ax2.plot(history['val_phys'], 'm--', label='Val Phys Loss')
        ax1.set_xlabel('Epochs')
        ax1.set_ylabel('R²', color='g')
        ax2.set_ylabel('Phys Loss', color='m')
        plt.title('R² & Physics Penalty')
        ax1.legend(loc='upper left')
        ax2.legend(loc='upper right')

        plt.tight_layout()
        plot_path = os.path.join(save_dir, f"training_curve_{datetime.now().strftime('%Y%m%d_%H%M')}.png")
        plt.savefig(plot_path, dpi=300)
        logger.info(f"训练曲线已保存至: {plot_path}")
        plt.close()


